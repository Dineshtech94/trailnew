<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- ===================== -->
    <!-- DB TEST (OLD SERVLET) -->
    <!-- ===================== -->
    <servlet>
        <servlet-name>DBServlet</servlet-name>
        <servlet-class>com.fintech.DBServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DBServlet</servlet-name>
        <url-pattern>/db</url-pattern>
    </servlet-mapping>


    <!-- ===================== -->
    <!-- LOGIN -->
    <!-- ===================== -->
    <servlet>
        <servlet-name>login</servlet-name>
        <servlet-class>com.fintech.servlet.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>login</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>


    <!-- ===================== -->
    <!-- ADD PRODUCT -->
    <!-- ===================== -->
    <servlet>
        <servlet-name>addProduct</servlet-name>
        <servlet-class>com.fintech.servlet.AddProductServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>addProduct</servlet-name>
        <url-pattern>/addProduct</url-pattern>
    </servlet-mapping>


    <!-- ===================== -->
    <!-- VIEW PRODUCTS -->
    <!-- ===================== -->
    <servlet>
        <servlet-name>viewProducts</servlet-name>
        <servlet-class>com.fintech.servlet.ViewProductsServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>viewProducts</servlet-name>
        <url-pattern>/viewProducts</url-pattern>
    </servlet-mapping>


    <!-- ===================== -->
    <!-- OPTIONAL: HOME REDIRECT -->
    <!-- ===================== -->
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

</web-app>
